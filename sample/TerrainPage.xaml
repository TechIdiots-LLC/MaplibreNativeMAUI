<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:maplibre="clr-namespace:MapLibreNative.Maui.Handlers;assembly=MapLibreNative.Maui.Handlers"
             x:Class="MauiSample.TerrainPage"
             Title="3D Terrain">

    <!-- Same single-scroll layout as the other demos: the map has a bounded
         height (set in code-behind) with the controls flowing beneath it. -->
    <ScrollView>
        <VerticalStackLayout Spacing="0">

            <maplibre:MapLibreMap
                x:Name="Map"
                HeightRequest="400"
                ShowNavigationControls="True"
                NavigationControlPosition="TopRight"
                AttributionControlPosition="BottomLeft" />

            <VerticalStackLayout Spacing="8" Padding="12">

                <Label FontAttributes="Bold" FontSize="16" Text="3D Terrain Toggle" />

                <Label TextColor="Gray" FontSize="12" Text=
                    "OSM raster with a hillshade layer over the Mapterhorn DEM (Innsbruck). Tap the button to drape the map over 3D terrain; tilt with two fingers to see the relief." />

                <Button x:Name="ToggleButton"
                        Text="Enable 3D Terrain"
                        Clicked="OnToggleTerrain"
                        BackgroundColor="#1E88E5" TextColor="White"
                        Padding="12,6" HorizontalOptions="Start" />

                <Label x:Name="StatusLabel" FontSize="12" TextColor="Gray" Text="Terrain: off" />

            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
