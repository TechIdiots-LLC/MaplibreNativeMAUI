<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:maplibre="clr-namespace:MapLibreNative.Maui.Handlers;assembly=MapLibreNative.Maui.Handlers"
             xmlns:local="clr-namespace:MauiSample"
             x:DataType="local:OfflineViewModel"
             x:Class="MauiSample.OfflinePage"
             Title="Offline">

    <Grid RowDefinitions="*, Auto">

        <!--
            Offline regions demo. The map and MbglOfflineManager share the same
            cache database (MbglCache.DefaultPath), so a downloaded region is
            served to the map even with the network forced offline.
        -->
        <maplibre:MapLibreMap
            Grid.Row="0"
            x:Name="Map"
            StyleUrl="https://demotiles.maplibre.org/style.json" />

        <VerticalStackLayout Grid.Row="1" Spacing="8" Padding="12">

            <Label FontAttributes="Bold" Text="Offline Regions Demo" FontSize="16" />
            <Label TextColor="Gray" FontSize="12" Text=
                "Download the visible region, then toggle offline — the map keeps working from the cache." />

            <HorizontalStackLayout Spacing="8">
                <Button Text="⬇  Download visible region"
                        Clicked="OnDownloadRegion"
                        BackgroundColor="#1E88E5" TextColor="White"
                        Padding="12,6" />
                <Button Text="☰  List"
                        Clicked="OnListRegions"
                        Padding="12,6" />
                <Button Text="🗑  Delete all"
                        Clicked="OnDeleteAll"
                        BackgroundColor="#E53935" TextColor="White"
                        Padding="12,6" />
                <Button x:Name="OfflineToggle"
                        Text="Go offline"
                        Clicked="OnToggleOffline"
                        Padding="12,6" />
            </HorizontalStackLayout>

            <Label Text="{Binding Status}" FontSize="12" TextColor="Gray" />

        </VerticalStackLayout>

    </Grid>
</ContentPage>
