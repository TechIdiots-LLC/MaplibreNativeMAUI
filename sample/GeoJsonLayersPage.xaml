<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:maplibre="clr-namespace:MapLibreNative.Maui.Handlers;assembly=MapLibreNative.Maui.Handlers"
             xmlns:local="clr-namespace:MauiSample"
             x:DataType="local:GeoJsonLayersViewModel"
             x:Class="MauiSample.GeoJsonLayersPage"
             Title="GeoJSON Layers">

    <!-- Single continuous scroll: map at the top (bounded height set in
         code-behind) with controls flowing directly beneath. Dragging the map
         pans it; dragging the controls scrolls the page. -->
    <ScrollView>
        <VerticalStackLayout Spacing="0">

            <maplibre:MapLibreMap
                x:Name="Map"
                HeightRequest="400"
                StyleUrl="{Binding StyleUrl}" />

            <VerticalStackLayout Spacing="8" Padding="12">

                <Label Text="GeoJSON Layers demo — polygon park + walking route" FontAttributes="Bold" />

                <FlexLayout Wrap="Wrap" JustifyContent="Start">
                    <Button Text="Add Polygon"    Clicked="OnAddPolygon"    Margin="0,0,8,8" />
                    <Button Text="Remove Polygon" Clicked="OnRemovePolygon" Margin="0,0,8,8" />
                    <Button Text="Toggle Route"   Clicked="OnToggleRoute"   Margin="0,0,8,8" />
                </FlexLayout>

                <Label Text="{Binding Status}" FontSize="12" TextColor="Gray" />

            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
