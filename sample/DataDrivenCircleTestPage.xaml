<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:maplibre="clr-namespace:MapLibreNative.Maui.Handlers;assembly=MapLibreNative.Maui.Handlers"
             xmlns:local="clr-namespace:MauiSample"
             x:DataType="local:DataDrivenCircleTestViewModel"
             x:Class="MauiSample.DataDrivenCircleTestPage"
             Title="Data-Driven Test">

    <!-- Single continuous scroll: map at the top (bounded height set in
         code-behind) with the run button and the (potentially long) test-log
         status text flowing directly beneath, all in one scroll. Dragging the
         map pans it; dragging the controls/log scrolls the page. -->
    <ScrollView>
        <VerticalStackLayout Spacing="0">
            <maplibre:MapLibreMap x:Name="Map"
                                  HeightRequest="400"
                                  StyleUrl="{Binding StyleUrl}"
                                  MapReady="OnMapReady" />

            <HorizontalStackLayout Spacing="8" Padding="8">
                <Button x:Name="RunTestButton" Text="Run Test" Clicked="OnRunTest" />
            </HorizontalStackLayout>

            <Label Text="{Binding Status}" Padding="8,4" FontFamily="Courier" FontSize="11" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
