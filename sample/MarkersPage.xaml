<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:maplibre="clr-namespace:MapLibreNative.Maui.Handlers;assembly=MapLibreNative.Maui.Handlers"
             xmlns:overlays="clr-namespace:MapLibreNative.Maui.Handlers.Overlays;assembly=MapLibreNative.Maui.Handlers"
             xmlns:local="clr-namespace:MauiSample"
             x:Class="MauiSample.MarkersPage"
             x:DataType="local:MarkersViewModel"
             Title="Markers">

    <!--
        Data-bound markers: MapLibreMap.ItemsSource is bound to an ObservableCollection<LandmarkItem>
        and ItemTemplate materialises each item as a Pin (SDF sprite + label). Add/Remove/Reset mutate
        the collection and the map updates live. The status row shows the current VisibleRegion, updated
        on every camera-idle. Tapping a marker identifies it via a rendered-feature query.
    -->
    <!-- Single continuous scroll: map at the top (bounded height set in
         code-behind) with controls flowing directly beneath. Dragging the map
         pans it; dragging the controls scrolls the page. -->
    <ScrollView>
        <VerticalStackLayout Spacing="0">
            <maplibre:MapLibreMap x:Name="Map"
                                  HeightRequest="400"
                                  StyleUrl="{Binding StyleUrl}"
                                  ItemsSource="{Binding Landmarks}"
                                  MapReady="OnMapReady"
                                  CameraIdle="OnCameraIdle"
                                  MapClick="OnMapClick">
                <maplibre:MapLibreMap.ItemTemplate>
                    <DataTemplate x:DataType="local:LandmarkItem">
                        <overlays:Pin Location="{Binding Location}"
                                      Label="{Binding Name}"
                                      TintColor="{Binding Color}" />
                    </DataTemplate>
                </maplibre:MapLibreMap.ItemTemplate>
            </maplibre:MapLibreMap>

            <HorizontalStackLayout Padding="8,4" Spacing="8">
                <Button Text="Add pin" Command="{Binding AddMarkerCommand}" />
                <Button Text="Remove last" Command="{Binding RemoveLastCommand}" />
                <Button Text="Reset" Command="{Binding ResetCommand}" />
            </HorizontalStackLayout>

            <Label Text="{Binding Status}" Padding="8,4" />
            <Label Text="{Binding RegionText}" Padding="8,0,8,6" FontSize="12" TextColor="Gray" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
